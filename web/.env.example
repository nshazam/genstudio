# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # SERVER ONLY, bypasses RLS

# ---- Cloud Run GPU worker ----
WORKER_URL=https://genstudio-worker-xxxx.run.app   # from `deploy.sh` output
WORKER_SECRET=some-long-random-string              # same value set on the Cloud Run service
# Service account JSON (one line) with roles/run.invoker on the worker service:
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account", ...}

# ---- Cloudflare R2 (output storage) ----
R2_ENDPOINT=https://<acct>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET=genstudio
R2_PUBLIC_BASE=https://media.yourdomain.com  # R2 public/custom domain

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_100=price_xxx
STRIPE_PRICE_500=price_xxx
STRIPE_PRICE_2000=price_xxx
